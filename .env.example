# GW-LINK OmniAI API environment variables (copy to .env for local use)

# HTTP port for the product API (default 8787)
PORT=8787

# GW-LINK AI gateway base URL
GW_LINK_GATEWAY_BASE_URL=https://gateway.gw-link.local

# Path to the product model catalog (default config/models.json)
GW_LINK_MODEL_CONFIG_PATH=config/models.json

# Path to the credit-package catalog served by GET /v1/packages (default
# config/credit-packages.json).
# GW_LINK_PACKAGES_CONFIG_PATH=config/credit-packages.json

# Passwordless login dev codes. Defaults on outside production, off when
# NODE_ENV=production. NEVER set this to true in production: the start-login
# response would expose verification codes.
# GW_LINK_AUTH_DEV_CODES_ENABLED=true

# Initial credit grant for newly created users (default 100). Balance is a
# server-side ledger; generations deduct the model's creditUnitCost on success.
# GW_LINK_INITIAL_CREDITS=100

# Dev-only credit top-up endpoint (POST /v1/credits/topup grants credits
# directly, no real payment). Defaults on outside production, off when
# NODE_ENV=production. NEVER enable in production: it lets any authenticated
# user mint free credits. Real payment will drive top-ups via webhooks.
# GW_LINK_DEV_TOPUP_ENABLED=true

# Postgres connection string. When unset, the API runs fully in-memory
# (data is lost on restart). When set, the API uses Drizzle-backed services.
#
# Supabase direct connection (port 5432):
#   postgresql://postgres:<password>@db.<ref>.supabase.co:5432/postgres
# Supabase transaction pooler (port 6543) is also supported; the client sets
#   prepare:false so prepared statements work through the pooler.
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/postgres

# Desktop app: base URL of the product API (default http://localhost:8787)
VITE_API_BASE_URL=http://localhost:8787

# API CORS allowed origins (comma-separated). Unset reflects the request origin
# (development only). In production set explicit origins, e.g.:
# GW_LINK_CORS_ORIGINS=https://app.example.com

# Provider API keys (referenced by config/models.json `apiKeyEnv`). When set,
# text generation calls chat/completions and image generation calls
# images/generations synchronously; when unset, generation falls back to a
# queued placeholder (no real call). Generated images are stored in the object
# store and served at GET /files/<id> (inline data URL only when no store).
# OPENAI_API_KEY=sk-...

# Public base URL the API is reachable at, used to build generated-file URLs
# (default http://localhost:<PORT>).
# GW_LINK_PUBLIC_BASE_URL=https://api.example.com

# Directory for the local object store (generated image files). When unset,
# the store is in-memory (lost on restart). When set, files persist on disk.
# GW_LINK_OBJECT_STORE_DIR=.data/objects

# Video generation: point the video model's provider (config/models.json) at a
# real async video service (baseUrl + apiKeyEnv) and set its key. The provider
# submits to {baseUrl}/videos/generations and polls until completed. Without a
# configured key, video generation stays queued.

# Payment webhook signing secret. Enables POST /v1/payments/webhook signature
# verification (HMAC-SHA256 over the raw request body, hex-encoded in the
# x-gw-signature header, constant-time compare). If unset, the webhook
# rejects every event with 500 rather than processing an unsigned/unconfigured
# request. NEVER log or echo this value.
# GW_LINK_PAYMENT_WEBHOOK_SECRET=change-me

# Dev-only checkout completion endpoint (POST /v1/payments/dev-complete
# server-side signs a payment.succeeded event and runs it through the real
# webhook path, crediting the order's owner without a real payment provider).
# Defaults on outside production, off when NODE_ENV=production. NEVER enable
# in production: it lets any authenticated user complete their own orders
# without ever paying.
# GW_LINK_DEV_PAYMENTS_ENABLED=true

# Payment provider selection. config/payment-providers.json lists provider
# definitions ({ id, displayName, protocol, baseUrl, apiKeyEnv,
# webhookSecretEnv }) plus an activeProvider; set this to override which
# provider id is active (default: the config file's activeProvider, "fake").
# GW_LINK_PAYMENT_PROVIDER=fake

# Path to the payment-provider catalog (default
# config/payment-providers.json).
# GW_LINK_PAYMENT_PROVIDERS_CONFIG_PATH=config/payment-providers.json

# A real provider (e.g. Stripe) needs its own API key set in the env var its
# config entry names via apiKeyEnv (e.g. STRIPE_API_KEY=sk_...). Without
# that key set, the provider falls back to a mock checkout URL and makes no
# real HTTP call.

# Admin allowlist for GET /v1/admin/orders (comma-separated emails, e.g.
# admin@example.com,ops@example.com). The endpoint requires a valid session
# (401 if unauthenticated) and rejects any authenticated user whose email is
# not in this list (403 { error: "Admin access required" }). Empty/unset means
# no one can pass the allowlist check.
# GW_LINK_ADMIN_EMAILS=admin@example.com

# Additional kill-switch for the (already admin-authenticated) GET
# /v1/admin/orders endpoint: even an allowlisted admin gets 403 { error:
# "Admin orders are disabled" } when this is off. Defaults on outside
# production, off when NODE_ENV=production. Setting this to true while
# NODE_ENV=production throws at boot — it can never be enabled in production.
# GW_LINK_DEV_ADMIN_ENABLED=true
